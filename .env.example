PORT=5000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hamare
DB_USER=root
DB_PASSWORD=

# Auth
# bcrypt hashes are 60 chars — extend `users.password` to VARCHAR(255) in MySQL if it is still VARCHAR(50)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# OTP delivery (email)
# For Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=superauctionapp@gmail.com
# SMTP_PASS=<GMAIL_APP_PASSWORD>
# SMTP_FROM="Humare Rishte <superauctionapp@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# If you're on a corporate network / inspection proxy and see TLS errors, you can set this to false.
# Prefer keeping it true.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# OTP delivery (SMS via webhook; optional)
SMS_WEBHOOK_URL=
